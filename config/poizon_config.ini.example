password = yourpassword

[Brands]
list = PUMA, Adidas, New Balance, Under Armour, ASICS, Jordan, THE NORTH FACE, Nike, Adidas Originals, FILA, Reebok, Vans, Converse, FILA KIDS, Kappa, UGG

[Crawl]
